# Copy this file to .env for local development. All values are local-only defaults;
# this project never requires real secrets, cloud accounts, or API keys.

# PostgreSQL (started via `pnpm db:up`; credentials match docker-compose.yml)
DATABASE_URL="postgresql://shopops:shopops_local_dev@localhost:5432/shopops"

# Canonical application origin. State-changing API requests must send a matching
# Origin header (CSRF protection), and it is used to build absolute URLs.
APP_URL="http://localhost:3000"
